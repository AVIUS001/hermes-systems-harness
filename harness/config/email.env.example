# Copy to harness/config/email.env and fill in private values.
# Do not commit the real file.

HERMES_SMTP_HOST=smtp.example.com
HERMES_SMTP_PORT=587
HERMES_SMTP_USER=you@example.com
HERMES_SMTP_PASSWORD=replace-with-app-password
HERMES_SMTP_FROM=you@example.com
HERMES_BRIEF_RECIPIENT=you@example.com
